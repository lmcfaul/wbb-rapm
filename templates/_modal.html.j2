<div id="modal-backdrop" onclick="closeModal()"></div>
<div id="modal"></div>
<script src="{{ rel }}data/ratings_{{ season }}.js"></script>
<script src="{{ rel }}data/history.js"></script>
<script src="{{ rel }}data/trends_{{ season }}.js"></script>
<script>
let D = window.WBB_DATA.players;  // reassigned when the leaderboard's model toggle loads another file
const HIST = window.WBB_HISTORY || {};
const TRENDS = window.WBB_TRENDS || {labels: [], players: {}};
const seasonLabel = s => (s - 1) + '–' + String(s).slice(2);
const fmt1 = x => x == null || !isFinite(x) ? '—' : (x >= 0 ? '+' : '') + x.toFixed(1);
const cls = x => x >= 0 ? 'num-good' : 'num-bad';
// small muted second line: raw on-court rating + teammate / competition adjustments
const sub = (p, kind) => `<span class="sub">raw ${fmt1(p['raw_' + kind])} tm ${fmt1(p['tm_' + kind])} opp ${fmt1(p['opp_' + kind])}</span>`;

function breakdownTable(p) {
  if (p.raw_net == null) return '';
  const row = (label, k) => `
    <tr><td class="l muted">${label}</td>
      <td class="${cls(p[k + '_off'])}">${fmt1(p[k + '_off'])}</td>
      <td class="${cls(p[k + '_def'])}">${fmt1(p[k + '_def'])}</td>
      <td class="${cls(p[k + '_net'])}">${fmt1(p[k + '_net'])}</td></tr>`;
  return `<div style="margin-top:16px"><b class="small">Rating breakdown <span class="muted" style="font-weight:400">(per 100 possessions)</span></b>
    <table class="small" style="margin-top:6px;font-size:12px"><thead><tr>
      <th class="l"></th><th>Off</th><th>Def</th><th>Total</th>
    </tr></thead><tbody>
      ${row('Raw on-court +/-', 'raw')}
      ${row('Teammate adjustment', 'tm')}
      ${row('Competition adjustment', 'opp')}
      <tr><td class="l muted">RAPM (adjusted)</td>
        <td class="${cls(p.orapm)}"><b>${fmt1(p.orapm)}</b></td>
        <td class="${cls(p.drapm)}"><b>${fmt1(p.drapm)}</b></td>
        <td class="${cls(p.rapm)}"><b>${fmt1(p.rapm)}</b></td></tr>
    </tbody></table>
    <div class="sub" style="margin-top:4px">Raw + adjustments &asymp; RAPM; ridge shrinkage means the rows don't sum exactly.</div></div>`;
}

// season split into three date phases, each refit separately: the trend line
const TREND_MIN_MINUTES = 30;
function trendChart(id) {
  const t = TRENDS.players[String(id)];
  if (!t || TRENDS.labels.length < 2) return '';
  const pts = t.map(r => ({phase: r[0], o: r[1], d: r[2], r: r[3], min: r[4]}));
  if (!pts.some(p => p.min >= TREND_MIN_MINUTES)) return '';
  const names = TRENDS.labels.length === 2 ? ['1st half', '2nd half']
              : TRENDS.labels.length === 3 ? ['Early', 'Mid', 'Late']
              : TRENDS.labels.map((_, i) => 'P' + (i + 1));
  const W = 320, H = 90, PAD = 26;
  const vals = pts.map(p => p.r);
  const lo = Math.min(...vals, 0) - 1, hi = Math.max(...vals, 0) + 1;
  const x = i => PAD + i * (W - 2 * PAD) / (pts.length - 1);
  const y = v => H - PAD / 2 - (v - lo) * (H - PAD) / (hi - lo);
  const solid = pts.filter(p => p.min >= TREND_MIN_MINUTES);
  const line = solid.map((p, i) => `${i ? 'L' : 'M'}${x(p.phase).toFixed(1)},${y(p.r).toFixed(1)}`).join(' ');
  const dots = pts.map(p => {
    const thin = p.min < TREND_MIN_MINUTES;
    return `<circle cx="${x(p.phase).toFixed(1)}" cy="${y(p.r).toFixed(1)}" r="3.5"
      fill="${thin ? 'var(--muted)' : (p.r >= 0 ? 'var(--good)' : 'var(--bad)')}" ${thin ? 'opacity=".4"' : ''}/>
    <text x="${x(p.phase).toFixed(1)}" y="${(y(p.r) - 8).toFixed(1)}" text-anchor="middle"
      font-size="10" fill="${thin ? 'var(--muted)' : 'var(--text)'}">${fmt1(p.r)}</text>`;
  }).join('');
  const cells = pts.map(p => `
    <td style="text-align:center">
      <div class="small"><b>${names[p.phase] || 'P' + (p.phase + 1)}</b></div>
      <div class="sub">${TRENDS.labels[p.phase]}</div>
      <div class="sub">O ${fmt1(p.o)} · D ${fmt1(p.d)} · ${Math.round(p.min)} min${p.min < TREND_MIN_MINUTES ? ' (thin)' : ''}</div>
    </td>`).join('');
  return `<div style="margin-top:16px"><b class="small">Season trend <span class="muted" style="font-weight:400">(ridge RAPM refit on each ${TRENDS.labels.length === 2 ? 'half' : 'phase'} of the season)</span></b>
    <svg width="${W}" height="${H}" style="display:block;margin:4px auto 0">
      <line x1="${PAD}" x2="${W - PAD}" y1="${y(0)}" y2="${y(0)}" stroke="var(--border)" stroke-dasharray="3 3"/>
      <path d="${line}" fill="none" stroke="var(--accent)" stroke-width="1.5"/>
      ${dots}
    </svg>
    <table style="width:100%;margin-top:2px"><tr>${cells}</tr></table>
    <div class="sub" style="margin-top:2px">Each phase is refit independently; phase ratings shrink harder and are noisier than the full-season number.</div></div>`;
}

function historyTable(id) {
  const h = HIST[String(id)];
  if (!h || h.length < 2) return '';  // single-season history just repeats the stats above
  const rows = h.slice().sort((a, b) => b.season - a.season).map(r => `
    <tr${r.season === {{ season }} ? ' style="background:var(--panel2)"' : ''}>
      <td class="l">${seasonLabel(r.season)}</td>
      <td class="l">${r.team || ''}</td>
      <td>${r.games}</td><td>${Math.round(r.minutes)}</td>
      <td class="${cls(r.orapm)}">${fmt1(r.orapm)}</td>
      <td class="${cls(r.drapm)}">${fmt1(r.drapm)}</td>
      <td class="${cls(r.rapm)}"><b>${fmt1(r.rapm)}</b></td>
      <td class="muted">#${r.rank}</td>
    </tr>`).join('');
  return `<div style="margin-top:16px"><b class="small">Season history</b>
    <table style="margin-top:6px"><thead><tr>
      <th class="l">Season</th><th class="l">Team</th><th>GP</th><th>Min</th>
      <th>ORAPM</th><th>DRAPM</th><th>RAPM</th><th>Rank</th>
    </tr></thead><tbody>${rows}</tbody></table></div>`;
}

function openModal(id) {
  const p = D.find(x => x.athlete_id === id);
  if (!p) return;
  const span = Math.max(...D.map(x => Math.abs(x.rapm)), 1);
  const bar = (v) => `<div class="bar"><div class="fill" style="width:${Math.min(Math.abs(v) / span * 100, 100)}%;
    margin-left:${v < 0 ? (50 - Math.min(Math.abs(v) / span * 50, 50)) : 50}%;
    background:${v >= 0 ? 'var(--good)' : 'var(--bad)'}"></div></div>`;
  document.getElementById('modal').innerHTML = `
    <span class="close" onclick="closeModal()">&times;</span>
    <div class="pcell" style="gap:14px;margin-bottom:14px">
      <img src="${p.headshot || ''}" style="width:64px;height:64px" onerror="this.style.visibility='hidden'">
      <div><b style="font-size:18px">${p.name}</b><br>
      <span class="muted">${p.team || ''} &middot; ${p.position || ''} &middot; ${p.games} GP &middot; ${Math.round(p.minutes)} min</span></div>
    </div>
    <div class="statgrid">
      <div class="stat"><div class="v ${cls(p.rapm)}">${fmt1(p.rapm)}</div><div class="k">RAPM (rank ${p.rank})</div></div>
      <div class="stat"><div class="v ${cls(p.orapm)}">${fmt1(p.orapm)}</div><div class="k">Offense</div></div>
      <div class="stat"><div class="v ${cls(p.drapm)}">${fmt1(p.drapm)}</div><div class="k">Defense</div></div>
    </div>
    <div style="margin-top:14px" class="small muted">Offense ${bar(p.orapm)} Defense ${bar(p.drapm)}
    Margin-model RAPM: <b class="${cls(p.rapm_margin)}">${fmt1(p.rapm_margin)}</b>
    ${p.low_sample ? '<br>Low-sample player: heavily shrunk toward 0 by the regularization; read with care.' : ''}
    ${window.WBB_DATA.model && window.WBB_DATA.model !== 'ridge' ? `<br>Viewing <b>${window.WBB_DATA.model}</b> ratings; the season trend and history below always use ridge.` : ''}</div>
    ${trendChart(p.athlete_id)}
    ${breakdownTable(p)}
    ${historyTable(p.athlete_id)}`;
  document.getElementById('modal').style.display = 'block';
  document.getElementById('modal-backdrop').style.display = 'block';
}
function closeModal() {
  document.getElementById('modal').style.display = 'none';
  document.getElementById('modal-backdrop').style.display = 'none';
}
</script>
