{% extends "base.html.j2" %}
{% block title %}WBB RAPM &middot; {{ season_label }} leaderboard{% endblock %}
{% block content %}
<div class="panel">
  <h2>Player leaderboard &mdash; {{ season_label }}</h2>
  {% if coverage_note %}<p class="small muted" style="margin-top:-4px">&#9888; {{ coverage_note }}</p>{% endif %}
  <div class="controls">
    <input type="text" id="f-search" placeholder="Search player or team...">
    <label>Team
      <select id="f-team"><option value="">All teams</option>
      {% for t in teams %}<option value="{{ t.team }}">{{ t.team }}</option>{% endfor %}
      </select>
    </label>
    <label>Min minutes <input type="number" id="f-min" value="{{ min_minutes_default }}" min="0" step="50" style="width:70px"></label>
    <label><input type="checkbox" id="f-low"> include low-sample</label>
    <span class="dl"><a href="data/ratings_{{ season }}.csv" download>&#8595; CSV</a></span>
    <span class="muted small" id="f-count"></span>
  </div>
  <table id="tbl">
    <thead><tr>
      <th data-k="rank" data-dir="asc">#</th>
      <th class="l" data-k="name">Player</th>
      <th class="l" data-k="team">Team</th>
      <th data-k="position">Pos</th>
      <th data-k="games">GP</th>
      <th data-k="minutes">Min</th>
      <th data-k="orapm">ORAPM</th>
      <th data-k="drapm">DRAPM</th>
      <th data-k="rapm" class="sorted-desc">RAPM</th>
    </tr></thead>
    <tbody id="tbody"></tbody>
  </table>
</div>
<div id="modal-backdrop" onclick="closeModal()"></div>
<div id="modal"></div>
{% endblock %}
{% block scripts %}
<script src="data/ratings_{{ season }}.js"></script>
<script src="data/history.js"></script>
<script>
const D = window.WBB_DATA.players;
const HIST = window.WBB_HISTORY || {};
const seasonLabel = s => (s - 1) + '–' + String(s).slice(2);
const fmt1 = x => x == null || !isFinite(x) ? '—' : (x >= 0 ? '+' : '') + x.toFixed(1);
const cls = x => x >= 0 ? 'num-good' : 'num-bad';
// small muted second line: raw on-court rating + teammate / competition adjustments
const sub = (p, kind) => `<span class="sub">raw ${fmt1(p['raw_' + kind])} tm ${fmt1(p['tm_' + kind])} opp ${fmt1(p['opp_' + kind])}</span>`;
let sortKey = 'rapm', sortDir = 'desc';

function rows() {
  const q = document.getElementById('f-search').value.toLowerCase();
  const team = document.getElementById('f-team').value;
  const minM = +document.getElementById('f-min').value || 0;
  const low = document.getElementById('f-low').checked;
  let out = D.filter(p =>
    (!q || p.name.toLowerCase().includes(q) || (p.team || '').toLowerCase().includes(q)) &&
    (!team || p.team === team) &&
    p.minutes >= minM && (low || !p.low_sample));
  out.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (typeof va === 'string') { va = (va || '').toLowerCase(); vb = (vb || '').toLowerCase();
      return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va); }
    return sortDir === 'asc' ? va - vb : vb - va;
  });
  return out;
}

function render() {
  const out = rows();
  document.getElementById('f-count').textContent = out.length + ' players';
  document.getElementById('tbody').innerHTML = out.map(p => `
    <tr class="player-row${p.low_sample ? ' low-sample' : ''}" onclick="openModal(${p.athlete_id})">
      <td class="muted">${p.rank}</td>
      <td class="l"><span class="pcell"><img loading="lazy" src="${p.headshot || ''}" onerror="this.style.visibility='hidden'">${p.name}${p.low_sample ? '<span class=badge>low min</span>' : ''}</span></td>
      <td class="l"><span class="tcell"><img loading="lazy" src="${p.team_logo || ''}" onerror="this.style.visibility='hidden'">${p.team || ''}</span></td>
      <td class="pos">${p.position || ''}</td>
      <td>${p.games}</td>
      <td>${Math.round(p.minutes)}</td>
      <td class="${cls(p.orapm)}">${fmt1(p.orapm)}${sub(p, 'off')}</td>
      <td class="${cls(p.drapm)}">${fmt1(p.drapm)}${sub(p, 'def')}</td>
      <td class="${cls(p.rapm)}"><b>${fmt1(p.rapm)}</b>${sub(p, 'net')}</td>
    </tr>`).join('');
}

document.querySelectorAll('#tbl th').forEach(th => th.addEventListener('click', () => {
  const k = th.dataset.k;
  if (sortKey === k) { sortDir = sortDir === 'desc' ? 'asc' : 'desc'; }
  else { sortKey = k; sortDir = th.dataset.dir || 'desc'; }
  document.querySelectorAll('#tbl th').forEach(h => h.classList.remove('sorted-desc', 'sorted-asc'));
  th.classList.add('sorted-' + sortDir);
  render();
}));
['f-search', 'f-team', 'f-min', 'f-low'].forEach(id =>
  document.getElementById(id).addEventListener('input', render));

function openModal(id) {
  const p = D.find(x => x.athlete_id === id);
  const span = Math.max(...D.map(x => Math.abs(x.rapm)), 1);
  const bar = (v) => `<div class="bar"><div class="fill" style="width:${Math.min(Math.abs(v) / span * 100, 100)}%;
    margin-left:${v < 0 ? (50 - Math.min(Math.abs(v) / span * 50, 50)) : 50}%;
    background:${v >= 0 ? 'var(--good)' : 'var(--bad)'}"></div></div>`;
  document.getElementById('modal').innerHTML = `
    <span class="close" onclick="closeModal()">&times;</span>
    <div class="pcell" style="gap:14px;margin-bottom:14px">
      <img src="${p.headshot || ''}" style="width:64px;height:64px" onerror="this.style.visibility='hidden'">
      <div><b style="font-size:18px">${p.name}</b><br>
      <span class="muted">${p.team || ''} &middot; ${p.position || ''} &middot; ${p.games} GP &middot; ${Math.round(p.minutes)} min</span></div>
    </div>
    <div class="statgrid">
      <div class="stat"><div class="v ${cls(p.rapm)}">${fmt1(p.rapm)}</div><div class="k">RAPM (rank ${p.rank})</div></div>
      <div class="stat"><div class="v ${cls(p.orapm)}">${fmt1(p.orapm)}</div><div class="k">Offense</div></div>
      <div class="stat"><div class="v ${cls(p.drapm)}">${fmt1(p.drapm)}</div><div class="k">Defense</div></div>
    </div>
    <div style="margin-top:14px" class="small muted">Offense ${bar(p.orapm)} Defense ${bar(p.drapm)}
    Margin-model RAPM: <b class="${cls(p.rapm_margin)}">${fmt1(p.rapm_margin)}</b>
    ${p.low_sample ? '<br>Low-sample player: heavily shrunk toward 0 by the ridge prior; read with care.' : ''}</div>
    ${breakdownTable(p)}
    ${historyTable(p.athlete_id)}`;
  document.getElementById('modal').style.display = 'block';
  document.getElementById('modal-backdrop').style.display = 'block';
}
function breakdownTable(p) {
  if (p.raw_net == null) return '';
  const row = (label, k, bold) => `
    <tr><td class="l muted">${label}</td>
      <td class="${cls(p[k + '_off'])}">${bold ? '<b>' : ''}${fmt1(p[k + '_off'])}${bold ? '</b>' : ''}</td>
      <td class="${cls(p[k + '_def'])}">${bold ? '<b>' : ''}${fmt1(p[k + '_def'])}${bold ? '</b>' : ''}</td>
      <td class="${cls(p[k + '_net'])}">${bold ? '<b>' : ''}${fmt1(p[k + '_net'])}${bold ? '</b>' : ''}</td></tr>`;
  return `<div style="margin-top:16px"><b class="small">Rating breakdown <span class="muted" style="font-weight:400">(per 100 possessions)</span></b>
    <table class="small" style="margin-top:6px;font-size:12px"><thead><tr>
      <th class="l"></th><th>Off</th><th>Def</th><th>Total</th>
    </tr></thead><tbody>
      ${row('Raw on-court +/-', 'raw')}
      ${row('Teammate adjustment', 'tm')}
      ${row('Competition adjustment', 'opp')}
      <tr><td class="l muted">RAPM (adjusted)</td>
        <td class="${cls(p.orapm)}"><b>${fmt1(p.orapm)}</b></td>
        <td class="${cls(p.drapm)}"><b>${fmt1(p.drapm)}</b></td>
        <td class="${cls(p.rapm)}"><b>${fmt1(p.rapm)}</b></td></tr>
    </tbody></table>
    <div class="sub" style="margin-top:4px">Raw + adjustments &asymp; RAPM; ridge shrinkage means the rows don't sum exactly.</div></div>`;
}

function historyTable(id) {
  const h = HIST[String(id)];
  if (!h || h.length < 2) return '';  // single-season history just repeats the stats above
  const rows = h.slice().sort((a, b) => b.season - a.season).map(r => `
    <tr${r.season === {{ season }} ? ' style="background:var(--panel2)"' : ''}>
      <td class="l">${seasonLabel(r.season)}</td>
      <td class="l">${r.team || ''}</td>
      <td>${r.games}</td><td>${Math.round(r.minutes)}</td>
      <td class="${cls(r.orapm)}">${fmt1(r.orapm)}</td>
      <td class="${cls(r.drapm)}">${fmt1(r.drapm)}</td>
      <td class="${cls(r.rapm)}"><b>${fmt1(r.rapm)}</b></td>
      <td class="muted">#${r.rank}</td>
    </tr>`).join('');
  return `<div style="margin-top:16px"><b class="small">Season history</b>
    <table style="margin-top:6px"><thead><tr>
      <th class="l">Season</th><th class="l">Team</th><th>GP</th><th>Min</th>
      <th>ORAPM</th><th>DRAPM</th><th>RAPM</th><th>Rank</th>
    </tr></thead><tbody>${rows}</tbody></table></div>`;
}

function closeModal() {
  document.getElementById('modal').style.display = 'none';
  document.getElementById('modal-backdrop').style.display = 'none';
}
render();
</script>
{% endblock %}
