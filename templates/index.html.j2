{% extends "base.html.j2" %}
{% block title %}WBB RAPM &middot; {{ season_label }} leaderboard{% endblock %}
{% block content %}
<div class="panel">
  <h2>Player leaderboard &mdash; {{ season_label }}</h2>
  {% if coverage_note %}<p class="small muted" style="margin-top:-4px">&#9888; {{ coverage_note }}</p>{% endif %}
  <div class="controls">
    {% if models|length > 1 %}
    <label>Model
      <select id="f-model">
        {% for m in models %}<option value="{{ m.key }}">{{ m.label }}</option>{% endfor %}
      </select>
    </label>
    {% endif %}
    <input type="text" id="f-search" placeholder="Search player or team...">
    <label>Team
      <select id="f-team"><option value="">All teams</option>
      {% for t in teams %}<option value="{{ t.team }}">{{ t.team }}</option>{% endfor %}
      </select>
    </label>
    <label>Min minutes <input type="number" id="f-min" value="{{ min_minutes_default }}" min="0" step="50" style="width:70px"></label>
    <label><input type="checkbox" id="f-low"> include low-sample</label>
    <span class="dl"><a id="csv-link" href="data/ratings_{{ season }}.csv" download>&#8595; CSV</a></span>
    <span class="muted small" id="f-count"></span>
  </div>
  <table id="tbl">
    <thead><tr>
      <th data-k="rank" data-dir="asc">#</th>
      <th class="l" data-k="name">Player</th>
      <th class="l" data-k="team">Team</th>
      <th data-k="position">Pos</th>
      <th data-k="games">GP</th>
      <th data-k="minutes">Min</th>
      <th data-k="orapm">ORAPM</th>
      <th data-k="drapm">DRAPM</th>
      <th data-k="rapm" class="sorted-desc">RAPM</th>
    </tr></thead>
    <tbody id="tbody"></tbody>
  </table>
</div>
{% endblock %}
{% block scripts %}
{% include "_modal.html.j2" %}
<script>
let sortKey = 'rapm', sortDir = 'desc';

function rows() {
  const q = document.getElementById('f-search').value.toLowerCase();
  const team = document.getElementById('f-team').value;
  const minM = +document.getElementById('f-min').value || 0;
  const low = document.getElementById('f-low').checked;
  let out = D.filter(p =>
    (!q || p.name.toLowerCase().includes(q) || (p.team || '').toLowerCase().includes(q)) &&
    (!team || p.team === team) &&
    p.minutes >= minM && (low || !p.low_sample));
  out.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (typeof va === 'string') { va = (va || '').toLowerCase(); vb = (vb || '').toLowerCase();
      return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va); }
    return sortDir === 'asc' ? va - vb : vb - va;
  });
  return out;
}

function render() {
  const out = rows();
  document.getElementById('f-count').textContent = out.length + ' players';
  document.getElementById('tbody').innerHTML = out.map(p => `
    <tr class="player-row${p.low_sample ? ' low-sample' : ''}" onclick="openModal(${p.athlete_id})">
      <td class="muted">${p.rank}</td>
      <td class="l"><span class="pcell"><img loading="lazy" src="${p.headshot || ''}" onerror="this.style.visibility='hidden'">${p.name}${p.low_sample ? '<span class=badge>low min</span>' : ''}</span></td>
      <td class="l"><span class="tcell"><img loading="lazy" src="${p.team_logo || ''}" onerror="this.style.visibility='hidden'">${p.team || ''}</span></td>
      <td class="pos">${p.position || ''}</td>
      <td>${p.games}</td>
      <td>${Math.round(p.minutes)}</td>
      <td class="${cls(p.orapm)}">${fmt1(p.orapm)}${sub(p, 'off')}</td>
      <td class="${cls(p.drapm)}">${fmt1(p.drapm)}${sub(p, 'def')}</td>
      <td class="${cls(p.rapm)}"><b>${fmt1(p.rapm)}</b>${sub(p, 'net')}</td>
    </tr>`).join('');
}

document.querySelectorAll('#tbl th').forEach(th => th.addEventListener('click', () => {
  const k = th.dataset.k;
  if (sortKey === k) { sortDir = sortDir === 'desc' ? 'asc' : 'desc'; }
  else { sortKey = k; sortDir = th.dataset.dir || 'desc'; }
  document.querySelectorAll('#tbl th').forEach(h => h.classList.remove('sorted-desc', 'sorted-asc'));
  th.classList.add('sorted-' + sortDir);
  render();
}));
['f-search', 'f-team', 'f-min', 'f-low'].forEach(id =>
  document.getElementById(id).addEventListener('input', render));

// regression-model toggle: each model has its own data file; loading one
// replaces window.WBB_DATA, then the table re-renders from the new ratings
const MODEL_FILES = {
  {% for m in models %}'{{ m.key }}': 'data/ratings_{{ season }}{% if m.key != 'ridge' %}_{{ m.key }}{% endif %}',
  {% endfor %}
};
const modelSel = document.getElementById('f-model');
if (modelSel) modelSel.addEventListener('change', e => {
  const base = MODEL_FILES[e.target.value];
  document.getElementById('csv-link').href = base + '.csv';
  const s = document.createElement('script');
  s.src = base + '.js';
  s.onload = () => { D = window.WBB_DATA.players; render(); };
  document.body.appendChild(s);
});
render();
</script>
{% endblock %}
