{% extends "base.html.j2" %}
{% block title %}Teams &middot; WBB RAPM {{ season_label }}{% endblock %}
{% block content %}
<div class="panel">
  <h2>D1 teams by minute-weighted RAPM &mdash; {{ season_label }}</h2>
  <table>
    <thead><tr><th>#</th><th class="l">Team</th><th>Record</th><th>Net margin</th><th>Team RAPM</th></tr></thead>
    <tbody>
    {% for t in teams %}
      <tr>
        <td class="muted">{{ loop.index }}</td>
        <td class="l"><span class="tcell"><img loading="lazy" src="{{ t.logo or '' }}" onerror="this.style.visibility='hidden'">
          <a href="teams/{{ t.team_id }}.html">{{ t.name }}</a></span></td>
        <td>{{ t.record }}</td>
        <td class="{{ 'num-good' if t.net_margin >= 0 else 'num-bad' }}">{{ '%+.1f'|format(t.net_margin) }}</td>
        <td class="{{ 'num-good' if t.team_rapm >= 0 else 'num-bad' }}"><b>{{ '%+.2f'|format(t.team_rapm) }}</b></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
