<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}WBB RAPM{% endblock %}</title>
<style>
:root {
  --bg: #0e1117; --panel: #161b25; --panel2: #1d2433; --text: #e6e9f0;
  --muted: #8b93a7; --accent: #4ea1ff; --good: #3ddc84; --bad: #ff6b6b;
  --border: #262e40;
}
* { box-sizing: border-box; }
body { margin: 0; font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
       background: var(--bg); color: var(--text); }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
header { background: var(--panel); border-bottom: 1px solid var(--border);
         padding: 14px 24px; display: flex; align-items: baseline; gap: 22px; flex-wrap: wrap; }
header h1 { font-size: 18px; margin: 0; letter-spacing: .5px; }
header h1 a { color: var(--text); }
header nav a { color: var(--muted); margin-right: 14px; font-size: 14px; }
header nav a.active, header nav a:hover { color: var(--text); }
.season-pick { margin-left: auto; font-size: 12px; color: var(--muted);
               display: flex; gap: 6px; align-items: center; }
.season-pick select { background: var(--panel2); color: var(--text); border: 1px solid var(--border);
                      border-radius: 6px; padding: 5px 8px; font-size: 13px; }
main { max-width: 1100px; margin: 24px auto; padding: 0 16px; }
.panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
         padding: 18px 20px; margin-bottom: 20px; }
h2 { font-size: 16px; margin: 0 0 12px; color: var(--text); }
.controls { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 14px; align-items: center; }
.controls input[type=text], .controls select, .controls input[type=number] {
  background: var(--panel2); color: var(--text); border: 1px solid var(--border);
  border-radius: 6px; padding: 7px 10px; font-size: 13px; }
.controls label { font-size: 12px; color: var(--muted); display: flex; gap: 6px; align-items: center; }
table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
th, td { padding: 7px 10px; text-align: right; border-bottom: 1px solid var(--border); white-space: nowrap; }
th { color: var(--muted); font-weight: 600; cursor: pointer; user-select: none; position: sticky; top: 0;
     background: var(--panel); font-size: 12px; text-transform: uppercase; letter-spacing: .4px; }
th.sorted-desc::after { content: " \25BE"; color: var(--accent); }
th.sorted-asc::after { content: " \25B4"; color: var(--accent); }
td.l, th.l { text-align: left; }
tr.player-row { cursor: pointer; }
tr.player-row:hover { background: var(--panel2); }
tr.low-sample td { opacity: .45; }
.pcell { display: flex; align-items: center; gap: 9px; }
.pcell img, .tcell img { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; background: #222; }
.tcell { display: flex; align-items: center; gap: 7px; }
.tcell img { border-radius: 4px; width: 20px; height: 20px; }
.pos { color: var(--muted); }
.num-good { color: var(--good); } .num-bad { color: var(--bad); }
.sub { display: block; font-size: 10px; font-weight: 400; color: var(--muted);
       letter-spacing: .2px; margin-top: 1px; opacity: .85; }
.muted { color: var(--muted); } .small { font-size: 12px; }
.badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; background: var(--panel2);
         color: var(--muted); border: 1px solid var(--border); margin-left: 6px; }
.statgrid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; }
.stat { background: var(--panel2); border-radius: 8px; padding: 10px 12px; }
.stat .v { font-size: 20px; font-weight: 700; } .stat .k { font-size: 11px; color: var(--muted); text-transform: uppercase; }
#modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.65); z-index: 50; }
#modal { display: none; position: fixed; z-index: 51; top: 8vh; left: 50%; transform: translateX(-50%);
         width: min(560px, 94vw); background: var(--panel); border: 1px solid var(--border);
         border-radius: 12px; padding: 22px; }
#modal .close { position: absolute; top: 10px; right: 14px; cursor: pointer; color: var(--muted); font-size: 20px; }
.bar { height: 8px; border-radius: 4px; background: var(--panel2); position: relative; margin: 4px 0 10px; }
.bar .fill { height: 100%; border-radius: 4px; }
footer { text-align: center; color: var(--muted); font-size: 12px; padding: 30px 0; }
.dl { font-size: 12px; }
</style>
</head>
<body>
<header>
  <h1><a href="{{ rel }}index.html">WBB RAPM</a> <span class="muted small">D1 women's basketball, adjusted player ratings</span></h1>
  <nav>
    <a href="{{ rel }}{{ nav.index }}" {% if page == 'index' %}class="active"{% endif %}>Leaderboard</a>
    <a href="{{ rel }}{{ nav.teams }}" {% if page == 'teams' %}class="active"{% endif %}>Teams</a>
    <a href="{{ rel }}{{ nav.stanford }}" {% if page == 'stanford' %}class="active"{% endif %}>Stanford</a>
    <a href="{{ rel }}{{ nav.about }}" {% if page == 'about' %}class="active"{% endif %}>About / Validation</a>
  </nav>
  {% if season_switch|length > 1 %}
  <label class="season-pick">Season
    <select onchange="location.href=this.value">
      {% for o in season_switch %}<option value="{{ o.href }}" {% if o.current %}selected{% endif %}>{{ o.label }}</option>{% endfor %}
    </select>
  </label>
  {% endif %}
</header>
<main>
{% block content %}{% endblock %}
</main>
<footer>RAPM = regularized adjusted plus-minus, points per 100 possessions vs average, adjusted for teammates and opponents.<br>
Data: ESPN via wehoop &middot; season {{ season_label }}</footer>
{% block scripts %}{% endblock %}
</body>
</html>
